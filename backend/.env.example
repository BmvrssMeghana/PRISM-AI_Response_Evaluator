# PRISM Backend - Environment Variables Example
# Copy this to .env and fill in your values

# ── PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/prism_db

# ── ChromaDB (persisted to disk) ─────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=prism_kb

# ── Embeddings ────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50

# ── Retrieval ─────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ── Ingestion ─────────────────────────────────────────────────────────
INGEST_SOURCES=truthfulqa,squad
INGEST_MIN_DOCS=1000

# ── App ───────────────────────────────────────────────────────────────
DEBUG=false

# ── LLM Providers ─────────────────────────────────────────────────────
# Set at least one API key to enable evaluation agents
GEMINI_API_KEY=AQ.Ab8RN6JJwiLir0Awc0owzn8ePLJy12sT2tYHDz5JebbemU7tPw
OPENAI_API_KEY=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
ANTHROPIC_API_KEY=

# Optional model name overrides
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

